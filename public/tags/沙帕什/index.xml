    <item>
      <title>沙帕什：埃尔之女、太阳女神与冥界之光</title>
      <link>https://vanvj00001.github.io/hugoblox-blog/posts/hebrew/%E6%B2%99%E5%B8%95%E4%BB%80/</link>
      <pubDate>Mon, 04 May 2026 10:39:00 +0800</pubDate>
